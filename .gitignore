# =============================================================================
# Mobile Shop POS — moblies-shop
# =============================================================================

# --- Dependencies ---
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Next.js ---
/.next/
/out/
.turbo/

# --- Build / TypeScript ---
/build
/dist
*.tsbuildinfo

# next-env.d.ts is generated by Next.js — keep it in git (do not ignore)

# --- Environment & secrets ---
.env
.env.local
.env.*.local
!.env.example

# --- Runtime uploads (shop logo, etc.) ---
/public/uploads/*
!/public/uploads/.gitkeep

# --- Backups (export / cron) ---
/backups/
*.backup.json

# --- Testing ---
/coverage
.nyc_output

# --- Logs & debug ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini

# --- IDE (local only) ---
.idea/
*.swp
*.swo
*~

# --- Deploy ---
.vercel

# --- Prisma (local SQLite if ever used) ---
*.db
*.db-journal

# --- Misc ---
*.pem
