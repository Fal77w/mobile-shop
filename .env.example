# =============================================================================
# Production / Docker — copy to .env and set your values
#
# Run (production — pull pre-built images):
#   docker compose pull && docker compose up -d
#
# Run (local build — tags images with names below):
#   docker compose up -d --build
# Demo:    docker compose --profile demo run --rm seed
#          (or: npm run docker:seed)
#
# Images are built by GitHub Actions and pushed to Docker Hub.
# Use the same tag for both images (e.g. run number from CI: 42).
# =============================================================================

# Local build defaults:
DOCKER_APP_IMAGE=mobile-app:local
DOCKER_MIGRATE_IMAGE=mobile-app-migrate:local

# Production (pull from Docker Hub — use matching CI tag, e.g. run number 42):
# DOCKER_APP_IMAGE=fal77w/mobile-app:42
# DOCKER_MIGRATE_IMAGE=fal77w/mobile-app-migrate:42

APP_PORT=3022
AUTH_URL=http://localhost:3022
AUTH_SECRET=change-me-run-openssl-rand-base64-32

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-password
ADMIN_NAME=Shop Admin
ADMIN_LOCALE=ar

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mobiles_shop

# Local dev (npm run dev) — requires: docker compose up -d postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mobiles_shop
