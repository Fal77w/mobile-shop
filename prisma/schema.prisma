generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ACCOUNTANT
  SALES
  EMPLOYEE
}

enum PaymentMethod {
  CASH
  CARD
  ON_ACCOUNT
}

enum StockMovementType {
  PURCHASE
  SALE
  SALE_RETURN
  PURCHASE_RETURN
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
}

enum RepairStatus {
  NEW
  IN_PROGRESS
  READY
  DELIVERED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(EMPLOYEE)
  locale       String   @default("ar")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sales           Sale[]
  purchases       Purchase[]
  saleReturns     SaleReturn[]
  purchaseReturns PurchaseReturn[]
  stockTransfers  StockTransfer[]
  repairOrders       RepairOrder[]
  programmingOrders  ProgrammingOrder[]
  stockMovements     StockMovement[]
}

model ShopSettings {
  id                 String   @id @default("default")
  shopName           String   @default("Mobile Shop")
  phone              String?
  address            String?
  invoicePrefix      String   @default("INV")
  logoUrl            String?
  invoiceFooter      String?
  invoiceShowBarcode Boolean  @default(true)
  updatedAt          DateTime @updatedAt
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories       Category[]
  products         Product[]
  transfersFrom    StockTransfer[] @relation("TransferFrom")
  transfersTo      StockTransfer[] @relation("TransferTo")
  stockMovements   StockMovement[]
}

model Category {
  id          String   @id @default(cuid())
  name        String
  warehouseId String
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  warehouse Warehouse  @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[] @relation("CategoryTree")
  products  Product[]

  @@unique([warehouseId, name])
  @@index([warehouseId])
  @@index([parentId])
}

model Product {
  id            String   @id @default(cuid())
  name          String
  sku           String
  barcode       String?
  categoryId    String
  warehouseId   String
  costPrice     Decimal  @db.Decimal(12, 2)
  sellingPrice  Decimal  @db.Decimal(12, 2)
  quantity      Int      @default(0)
  lowStockAlert Int      @default(5)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category          Category           @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  warehouse         Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  saleItems         SaleItem[]
  purchaseItems     PurchaseItem[]
  saleReturnItems   SaleReturnItem[]
  purchaseReturnItems PurchaseReturnItem[]
  stockTransfers    StockTransfer[]
  stockMovements    StockMovement[]

  @@unique([warehouseId, sku])
  @@index([warehouseId, categoryId])
  @@index([barcode])
  @@index([name])
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  totalDebt Decimal  @default(0) @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales    Sale[]
  payments Payment[]

  @@index([name])
  @@index([phone])
}

model Sale {
  id             String        @id @default(cuid())
  invoiceNumber  String        @unique
  customerId     String?
  customerName   String?
  paymentMethod  PaymentMethod
  subtotal       Decimal       @db.Decimal(12, 2)
  total          Decimal       @db.Decimal(12, 2)
  createdById    String
  createdAt      DateTime      @default(now())

  customer    Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdBy   User         @relation(fields: [createdById], references: [id], onDelete: Restrict)
  items       SaleItem[]
  saleReturns SaleReturn[]

  @@index([createdAt])
  @@index([customerId])
  @@index([paymentMethod])
}

model SaleItem {
  id                String  @id @default(cuid())
  saleId            String
  productId         String
  productName       String
  quantity          Int
  unitPrice         Decimal @db.Decimal(12, 2)
  costPriceSnapshot Decimal @db.Decimal(12, 2)
  lineTotal         Decimal @db.Decimal(12, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([saleId])
  @@index([productId])
}

model Purchase {
  id                 String   @id @default(cuid())
  supplierName       String
  supplierInvoiceNo  String?
  date               DateTime @db.Date
  total              Decimal  @db.Decimal(12, 2)
  createdById        String
  createdAt          DateTime @default(now())

  createdBy       User             @relation(fields: [createdById], references: [id], onDelete: Restrict)
  items           PurchaseItem[]
  purchaseReturns PurchaseReturn[]

  @@index([date])
  @@index([supplierName])
}

model PurchaseItem {
  id         String  @id @default(cuid())
  purchaseId String
  productId  String
  quantity   Int
  costPrice  Decimal @db.Decimal(12, 2)
  lineTotal  Decimal @db.Decimal(12, 2)

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([purchaseId])
  @@index([productId])
}

model SaleReturn {
  id          String   @id @default(cuid())
  saleId      String?
  date        DateTime @db.Date
  totalRefund Decimal  @db.Decimal(12, 2)
  notes       String?
  createdById String
  createdAt   DateTime @default(now())

  sale      Sale?            @relation(fields: [saleId], references: [id], onDelete: SetNull)
  createdBy User             @relation(fields: [createdById], references: [id], onDelete: Restrict)
  items     SaleReturnItem[]

  @@index([date])
  @@index([saleId])
}

model SaleReturnItem {
  id           String  @id @default(cuid())
  saleReturnId String
  productId    String
  quantity     Int
  refundAmount Decimal @db.Decimal(12, 2)
  costSnapshot Decimal @db.Decimal(12, 2)

  saleReturn SaleReturn @relation(fields: [saleReturnId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([saleReturnId])
  @@index([productId])
}

model PurchaseReturn {
  id          String   @id @default(cuid())
  purchaseId  String?
  date        DateTime @db.Date
  notes       String?
  createdById String
  createdAt   DateTime @default(now())

  purchase  Purchase?            @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  createdBy User                 @relation(fields: [createdById], references: [id], onDelete: Restrict)
  items     PurchaseReturnItem[]

  @@index([date])
  @@index([purchaseId])
}

model PurchaseReturnItem {
  id               String @id @default(cuid())
  purchaseReturnId String
  productId        String
  quantity         Int

  purchaseReturn PurchaseReturn @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)
  product        Product        @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([purchaseReturnId])
  @@index([productId])
}

model Expense {
  id        String   @id @default(cuid())
  title     String
  amount    Decimal  @db.Decimal(12, 2)
  date      DateTime @db.Date
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
}

model Payment {
  id         String   @id @default(cuid())
  customerId String
  amount     Decimal  @db.Decimal(12, 2)
  date       DateTime @db.Date
  notes      String?
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([date])
}

model StockTransfer {
  id              String   @id @default(cuid())
  fromWarehouseId String
  toWarehouseId   String
  productId       String
  quantity        Int
  notes           String?
  createdById     String
  createdAt       DateTime @default(now())

  fromWarehouse Warehouse @relation("TransferFrom", fields: [fromWarehouseId], references: [id], onDelete: Restrict)
  toWarehouse   Warehouse @relation("TransferTo", fields: [toWarehouseId], references: [id], onDelete: Restrict)
  product       Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdBy     User      @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([createdAt])
}

model InvoiceSequence {
  year       Int @id
  lastNumber Int @default(0)
}

model StockMovement {
  id            String            @id @default(cuid())
  productId     String
  warehouseId   String
  type          StockMovementType
  quantity      Int
  balanceAfter  Int
  referenceId   String?
  referenceType String?
  notes         String?
  createdById   String?
  createdAt     DateTime          @default(now())

  product     Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  createdBy   User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([warehouseId])
  @@index([createdAt])
  @@index([type])
}

model RepairOrder {
  id           String       @id @default(cuid())
  orderNumber  String       @unique
  customerName String
  phone        String
  deviceType   String
  issue        String
  cost         Decimal      @db.Decimal(12, 2)
  status       RepairStatus @default(NEW)
  notes        String?
  createdById  String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deliveredAt  DateTime?

  createdBy User @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([status])
  @@index([createdAt])
}

model ProgrammingOrder {
  id           String       @id @default(cuid())
  orderNumber  String       @unique
  customerName String
  phone        String
  deviceType   String
  serviceType  String
  cost         Decimal      @db.Decimal(12, 2)
  status       RepairStatus @default(NEW)
  notes        String?
  createdById  String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deliveredAt  DateTime?

  createdBy User @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([status])
  @@index([createdAt])
}
